{
  "ServiceName": "pitchmirror-api",
  "SourceConfiguration": {
    "AuthenticationConfiguration": {
      "AccessRoleArn": "arn:aws:iam::127214190437:role/AppRunnerECRAccessRole"
    },
    "AutoDeploymentsEnabled": true,
    "ImageRepository": {
      "ImageIdentifier": "127214190437.dkr.ecr.us-east-1.amazonaws.com/pitchmirror-api:latest",
      "ImageRepositoryType": "ECR",
      "ImageConfiguration": {
        "Port": "8080",
        "RuntimeEnvironmentVariables": {
          "AWS_REGION": "us-east-1",
          "RAW_BUCKET": "pitchmirror2-raw-omer-2026",
          "DERIVED_BUCKET": "pitchmirror2-derived-omer-2026",
          "JOBS_TABLE": "pitchmirror2-jobs",
          "PRESIGN_EXPIRES_SECONDS": "900",
          "RAW_TTL_DAYS": "7",
          "NODE_ENV": "production",
          "ALLOWED_ORIGINS": "*",
          "PITCHMIRROR_SFN_ARN": "arn:aws:states:us-east-1:127214190437:stateMachine:pitchmirror2-stub-pipeline"
        }
      }
    }
  },
  "InstanceConfiguration": {
    "Cpu": "1 vCPU",
    "Memory": "2 GB",
    "InstanceRoleArn": "arn:aws:iam::127214190437:role/AppRunnerPitchMirrorInstanceRole"
  }
}
